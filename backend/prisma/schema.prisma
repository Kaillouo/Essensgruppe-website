// Prisma schema for Essensgruppe portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User accounts with role-based access
model User {
  id            String     @id @default(uuid())
  username      String     @unique
  email         String     @unique
  passwordHash  String     @map("password_hash")
  role          Role       @default(ABI27)
  status        UserStatus @default(PENDING)
  emailVerified Boolean    @default(false) @map("email_verified")
  balance       Int        @default(1000) // Starting gambling balance
  lastDailyClaim DateTime? @map("last_daily_claim") // Track daily coin claim
  avatarUrl     String?    @map("avatar_url")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relations
  posts              Post[]
  comments           Comment[]
  votes              Vote[]
  events             Event[]
  eventVotes         EventVote[]
  eventPhotos        EventPhoto[]
  announcements      Announcement[]
  transactions       Transaction[]
  gamesHistory       GameHistory[]
  predictions        Prediction[]
  predictionBets     PredictionBet[]
  emailVerification  EmailVerification?
  passwordReset      PasswordReset?
  sentMessages       DirectMessage[] @relation("SentMessages")
  receivedMessages   DirectMessage[] @relation("ReceivedMessages")
  contacts           Contact[]       @relation("UserContacts")
  contactOf          Contact[]       @relation("ContactOf")
  notifications              Notification[]
  blockedUsers               UserBlock[]              @relation("BlockedBy")
  blockedBy                  UserBlock[]              @relation("BlockedUser")
  notificationPreference     NotificationPreference?

  @@map("users")
}

enum Role {
  ABI27
  ESSENSGRUPPE_MITGLIED
  ADMIN
}

// Email verification tokens
model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// Password reset tokens
model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// App-wide settings (key/value store)
model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}

enum UserStatus {
  PENDING
  ACTIVE
  BANNED
}

// Forum posts (threads)
model Post {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  content   String   @db.Text
  imageUrl   String?  @map("image_url")
  visibility String   @default("ALL")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

// Nested comments system
model Comment {
  id              String   @id @default(uuid())
  postId          String   @map("post_id")
  parentCommentId String?  @map("parent_comment_id") // For nested replies
  userId          String   @map("user_id")
  content         String   @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment  Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies        Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([parentCommentId])
  @@map("comments")
}

// Upvote/downvote system for posts and comments
model Vote {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  targetId   String   @map("target_id") // Post or Comment ID
  targetType VoteType @map("target_type")
  value      Int      // +1 for upvote, -1 for downvote
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Note: targetId is polymorphic (can be Post or Comment ID based on targetType)
  // No direct relations to avoid foreign key conflicts

  @@unique([userId, targetId]) // One vote per user per target
  @@index([targetId])
  @@map("votes")
}

enum VoteType {
  POST
  COMMENT
}

// Event planning system (ABI 27)
model Event {
  id          String      @id @default(uuid())
  userId      String      @map("user_id") // Creator
  title       String
  description String      @db.Text
  date        DateTime?
  location    String?
  budget      Float?
  status      EventStatus @default(PROPOSED)
  votes       Int         @default(0) // Net votes (upvotes - downvotes)
  visibility  String      @default("ALL")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventVotes EventVote[]
  photos     EventPhoto[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("events")
}

// Per-user vote tracking for events
model EventVote {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  value     Int      // +1 upvote, -1 downvote
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("event_votes")
}

// Photos attached to events
model EventPhoto {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_photos")
}

// MC page announcements (admin only)
model Announcement {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("announcements")
}

enum EventStatus {
  PROPOSED
  IN_PLANNING
  COMPLETED
}

// Gambling balance transactions
model Transaction {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  amount    Int             // Positive for credits, negative for debits
  type      TransactionType
  game      String?         // Game name if gambling-related
  createdAt DateTime        @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("transactions")
}

enum TransactionType {
  INITIAL_BALANCE
  GAME_BET
  GAME_WIN
  PREDICTION_BET
  PREDICTION_WIN
  ADMIN_ADJUSTMENT
  DAILY_COINS
}

// Prediction market
model Prediction {
  id        String           @id @default(uuid())
  creatorId String           @map("creator_id")
  title     String
  closeDate DateTime         @map("close_date")
  status     PredictionStatus @default(OPEN)
  outcome    Boolean?         // true = YES won, false = NO won, null = not resolved yet
  visibility String           @default("ALL")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  creator User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  bets    PredictionBet[]

  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@map("predictions")
}

model PredictionBet {
  id           String   @id @default(uuid())
  predictionId String   @map("prediction_id")
  userId       String   @map("user_id")
  side         Boolean  // true = YES, false = NO
  amount       Int
  createdAt    DateTime @default(now()) @map("created_at")

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([predictionId, userId]) // one bet per user per prediction
  @@index([predictionId])
  @@index([userId])
  @@map("prediction_bets")
}

enum PredictionStatus {
  OPEN
  CLOSED
}

// Anonymous Abi Zeitung submissions (no user ID stored — fully anonymous)
model AbiSubmission {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("abi_submissions")
}

// Direct messages between users (auto-deleted after 24h)
model DirectMessage {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, read])
  @@index([createdAt])
  @@map("direct_messages")
}

// Persistent contact list (survives message deletion)
model Contact {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  contactId String   @map("contact_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contact User @relation("ContactOf", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@index([userId])
  @@map("contacts")
}

// Gambling games history
model GameHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  gameType  String   @map("game_type") // coinflip, dice, etc.
  bet       Int
  result    String   @db.Text // JSON string with game-specific result
  payout    Int
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameType])
  @@index([createdAt])
  @@map("games_history")
}

// Notification types
enum NotificationType {
  ADMIN_BROADCAST
  NEW_POST
  NEW_PREDICTION
  PREDICTION_CLOSED
  PREDICTION_REMINDER
  NEW_EVENT
  EVENT_STATUS_CHANGED
  DAILY_COINS
  NEW_MESSAGE
}

// In-app notifications
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  linkUrl   String?          @map("link_url")
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Chat block list (blocks DMs only, not forum visibility)
model UserBlock {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlockedBy", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@map("user_blocks")
}

// Per-user notification preferences (ADMIN_BROADCAST always on, not toggleable)
model NotificationPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique @map("user_id")
  newPost            Boolean @default(true) @map("new_post")
  newPrediction      Boolean @default(true) @map("new_prediction")
  predictionClosed   Boolean @default(true) @map("prediction_closed")
  predictionReminder Boolean @default(true) @map("prediction_reminder")
  newEvent           Boolean @default(true) @map("new_event")
  eventStatusChanged Boolean @default(true) @map("event_status_changed")
  dailyCoins         Boolean @default(true) @map("daily_coins")
  newMessage         Boolean @default(true) @map("new_message")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
